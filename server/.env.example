# Credenciales de tu cuenta Garmin Connect (NUNCA las subas a un repo público)
GARMIN_EMAIL=tu.email@ejemplo.com
GARMIN_PASSWORD=tu-contraseña

# Clave propia que la app usará para autenticarse contra este servidor.
# Genera algo largo y aleatorio, ej: openssl rand -hex 32
API_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Origen exacto donde vive tu app estática (GitHub Pages), para restringir CORS
ALLOWED_ORIGIN=https://dalimdaher-png.github.io

# Puerto local (los servicios de hosting suelen asignarlo automáticamente)
PORT=3000
